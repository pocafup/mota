    {
      "type": "function",
      "function": "function(){\nlet f = `对话${core.getFlag('arg1')}`;\nif (core.getFlag('arg4')) f = f + '02';\ncore.setFlag(f, true)\n}"
    },
    {
      "type": "hide",
      "loc": [
        "flag:arg2 ",
        "flag:arg3 "
      ],
      "remove": true,
      "time": 500
    }
