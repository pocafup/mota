                        },
                        {
                          "type": "tip",
                          "text": "获得1000金币"
                        }
                      ]
                    },
                    {
                      "case": "3",
                      "action": [
                        {
                          "type": "setValue",
                          "name": "item:book",
                          "operator": "+=",
                          "value": "1"
