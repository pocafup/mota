          ]
        },
        {
          "case": "48",
          "action": [
            {
              "type": "setValue",
              "name": "flag:content",
              "value": "'象骰子上5的形状是一种封印魔法，你最好记住它在你与49楼假魔王战斗时有用。'"
            }
          ]
        },
        {
          "case": "default",
          "action": [
            "没有本层对话信息，请在公共事件“对话”中配置！",
            {
              "type": "break",
              "n": 1
            }
          ]
