                {
                  "type": "setValue",
                  "name": "status:money",
                  "value": "flag:money1",
                  "operator": "-="
                },
                {
                  "type": "setValue",
                  "name": "flag:times1",
                  "value": "1",
                  "operator": "+="
                }
              ]
            },
            {
              "action": [
                {
                  "type": "setValue",
                  "name": "status:def",
