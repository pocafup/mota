{
  "_comment": "来源: core.material.items + core.values (live engine)。",
  "_schema": {
    "pickup": "踩格自动触发（引擎字段 itemEffect），效果结构见下",
    "use": "背包手动使用（引擎字段 useItemEffect），效果结构见下",
    "pickup/use 效果类型": {
      "stat": "{type,stat,base,ratio_scaled} 或 {type,stat,delta}。ratio_scaled=true 时 gain=base*floor_ratio",
      "multi": "{type,ops:[{stat,delta},...]}  多属性固定增量",
      "formula": "{type,stat,expr}  计算公式，变量为 hero.atk/def/hp 等",
      "debuff_remove": "{type,debuff}  清除状态异常",
      "custom": "{type}  逻辑复杂，模拟器需单独实现",
      "set_flags": "pickup 中的附加字段，{flag_key: value} 同步设置的 flags"
    }
  },

